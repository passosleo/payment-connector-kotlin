#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! command -v java >/dev/null 2>&1 && [ -f "$HOME/.bashrc" ]; then
  # Load local JAVA_HOME/PATH for GUI terminals or shells that did not source it.
  # shellcheck disable=SC1090
  source "$HOME/.bashrc" || true
fi

staged_files=()
while IFS= read -r -d '' file; do
  staged_files+=("$file")
done < <(git diff --cached --name-only -z --diff-filter=ACMR -- "*.kt" "*.kts")

if [ "${#staged_files[@]}" -eq 0 ]; then
  exit 0
fi

gradle_tasks=(spotlessApply spotlessCheck)

run_main_compile=false
run_test_compile=false

for file in "${staged_files[@]}"; do
  case "$file" in
    *.gradle.kts|settings.gradle.kts|src/main/kotlin/*)
      run_main_compile=true
      ;;
  esac

  case "$file" in
    *.gradle.kts|settings.gradle.kts|src/test/kotlin/*)
      run_test_compile=true
      ;;
  esac
done

if [ "$run_main_compile" = true ]; then
  gradle_tasks+=(compileKotlin)
fi

if [ "$run_test_compile" = true ]; then
  gradle_tasks+=(compileTestKotlin)
fi

./gradlew "${gradle_tasks[@]}"
git add -- "${staged_files[@]}"
